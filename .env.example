# ============================================================
# EleventhMedia Marketing Site — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ------------------------------------------------------------
# Webhook / CRM Integration (Optional)
# ------------------------------------------------------------
# When set, form submissions are POST'd as JSON to this URL.
# Use this to connect to Zapier, Make.com, GoHighLevel, HubSpot,
# your own API route, or any CRM that accepts webhook payloads.
#
# Payload shape:
# {
#   "name": "...",
#   "companyName": "...",
#   "phone": "...",
#   "email": "...",
#   "submittedAt": "2024-01-01T00:00:00.000Z"
# }
NEXT_PUBLIC_WEBHOOK_URL=

# ------------------------------------------------------------
# Site URL (used for canonical URLs and OG meta tags)
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ------------------------------------------------------------
# Calendly URL (already hardcoded in CalendlyEmbed.tsx)
# Override here if you change scheduling links in the future.
# ------------------------------------------------------------
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/taylor-marcheleventh/30min
